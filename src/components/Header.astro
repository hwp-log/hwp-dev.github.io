---
import { SITE_TITLE } from '../consts';
import avatarHwp from '../assets/hwp.png';
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-wrap">
      <img src={avatarHwp.src} alt="" class="avatar-img" />
      <span class="logo">Engineering-Log</span>
    </a>

    <nav class="nav">
      <a href="/">TechDeepDive</a>
      <a href="/techstory">TechStory</a>
      <a href="/ai">A.I</a>
      <a href="/philosophy">Philosophy</a>
      <a href="/about">About Me</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: #050608;
    border-bottom: 1px solid #1a1a1a;
  }

  .header-inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 16px 24px 8px;
    display: flex;
    align-items: center;
    justify-content: space-between; /* 좌: 로고, 우: 메뉴 */
    gap: 16px;
  }

  .logo-wrap {
    display: flex;
    align-items: center;       /* 아바타-텍스트 수직 가운데 */
    gap: 8px;                  /* 아바타와 hwp.dev 사이 간격 */
    text-decoration: none;     /* 로고 링크 언더라인 제거 */
    color: #e5e5e5;
  }

  .logo-wrap .logo {
    text-decoration: none;     /* 혹시 모를 underline 강제 제거 */
  }

  .avatar-img {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    transform: translateY(-5px);
  }

  .logo {
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1;
  }

  .nav {
    display: flex;
    gap: 12px;
    font-size: 0.95rem;
  }

  .nav a {
    color: #1da1f2;
    font-weight: bold;
    text-decoration: none;
  }

  .nav a:hover {
    color: white;
    transition: color 0.8s ease, border-bottom-color 0.8s ease;
    text-decoration: none;
  }

  /* 모바일일 때는 메뉴를 아래 줄로 */
  @media (max-width: 640px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
